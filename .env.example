# =============================================
# Root .env.example — скопируйте нужные значения
# в backend/.env и frontend/.env.local
# =============================================

# --- BACKEND ---

ENVIRONMENT=production

# SMTP mail.ru (получить пароль приложения на https://account.mail.ru/security)
MAIL_SERVER=smtp.mail.ru
MAIL_PORT=465
MAIL_USERNAME=your_email@mail.ru
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@proektgroup.ru
MAIL_STARTTLS=false
MAIL_SSL_TLS=true

# Email администратора — куда приходят заявки
ADMIN_EMAIL=admin@proektgroup.ru

# Redis
REDIS_URL=redis://redis:6379

# CORS — укажите ваш домен
ALLOWED_ORIGINS=["https://proektgroup.ru","https://www.proektgroup.ru"]

# Название сайта
SITE_NAME=Проектная группа

# --- FRONTEND ---

# В production Next.js обращается к бэкенду через Nginx (не напрямую)
# Это значение нужно только для локальной разработки вне Docker
BACKEND_URL=http://backend:8000
NODE_ENV=production
